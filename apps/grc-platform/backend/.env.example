# Database — MySQL 8+
# Format: user:password@tcp(host:port)/dbname?parseTime=true
DB_DSN=
# Asgardeo JWT validation — IdP-1 (GRC web app; full API scope)
AUTH_JWKS_ENDPOINT=
AUTH_ISSUER=
AUTH_AUDIENCE=
# Set to false ONLY for local development (skips JWT signature verification)
AUTH_TOKEN_VALIDATOR_ENABLED=true

# IdP-2 (Evidence Portal; scope restricted to /api/v1/evidence-app/*) — OPTIONAL.
# Set AUTH_ISSUER_2 to enable a second issuer; when set, all four vars below are
# required. Tokens from this IdP are capped at the SUBMIT_EVIDENCE privilege ceiling
# regardless of AUTH_GROUP_ROLE_MAP_2. Leave AUTH_ISSUER_2 blank for single-IdP.
# AUTH_ISSUER_2=https://api.asgardeo.io/t/<their-org>/oauth2/token
# AUTH_JWKS_ENDPOINT_2=https://api.asgardeo.io/t/<their-org>/oauth2/jwks
# AUTH_AUDIENCE_2=<grc-backend-api-audience-in-their-org>
# Comma-separated ext=grc pairs mapping IdP-2 groups to GRC roles (unmapped groups dropped):
# AUTH_GROUP_ROLE_MAP_2=grc_evidence_submitter=audit_internal_team


# Compliance Entity — internal data service
COMPLIANCE_ENTITY_BASE_URL=http://localhost:8081

# HR entity GraphQL service (real Choreo-hosted hr_entity — OAuth2
# client-credentials, same app/credentials subscribed to in Choreo Dev Portal)
HR_ENTITY_GRAPHQL_URL=
HR_ENTITY_CLIENT_ID=
HR_ENTITY_CLIENT_SECRET=
HR_ENTITY_TOKEN_URL=

# Server
PORT=:8080
# Frontend origin allowed for CORS (defaults to http://localhost:3000 if not set)
CORS_ALLOWED_ORIGIN=http://localhost:3000

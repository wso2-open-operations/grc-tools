# Database — MySQL 8+
# Format: user:password@tcp(host:port)/dbname?parseTime=true
DB_DSN=
# Asgardeo JWT validation
AUTH_JWKS_ENDPOINT=
AUTH_ISSUER=
AUTH_AUDIENCE=
# Set to false ONLY for local development (skips JWT signature verification)
AUTH_TOKEN_VALIDATOR_ENABLED=true


# Azure Blob Storage (risk and audit evidence files)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=

# HR entity GraphQL service
# Local dev: point at `go run ./cmd/hrmock` (defaults to http://localhost:9090/graphql).
# Production: the real hr_entity service URL on Choreo.
HR_ENTITY_GRAPHQL_URL=http://localhost:9090/graphql

# Server
PORT=:8080
# Frontend origin allowed for CORS (defaults to http://localhost:3000 if not set)
CORS_ALLOWED_ORIGIN=http://localhost:3000

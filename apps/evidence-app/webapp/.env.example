# Frontend environment variables
# Copy this file to .env.local and fill in your values.

# Asgardeo OAuth application (build-time). Required — the web app fails to start
# if either is unset. Set them to your Asgardeo app's client id and tenant base URL.
VITE_ASGARDEO_CLIENT_ID=your-client-id-here
VITE_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/<your-org>

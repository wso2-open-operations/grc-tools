# Runner environment variables
# Copy this file to .env and fill in your values.
# Alternatively run: wso2-runner configure

# Backend server URL (local dev, or the deployed Choreo/VM URL).
CLOUD_URL=http://localhost:8000

# Your WSO2 email — used only as a login_hint on the Asgardeo sign-in page.
USER_EMAIL=

# Asgardeo tenant/org (same tenant as the web frontend and backend). Required.
ASGARDEO_ORG=
# Client ID of the Runner's own Asgardeo "Native Application" registration
# (public client, PKCE, no secret) — see the Asgardeo setup docs.
ASGARDEO_CLIENT_ID=

# LLM provider: azure | anthropic | gemini | ollama
AGENT_PROVIDER=azure
AGENT_MODEL=gpt-4.1-mini

# Azure OpenAI (used when AGENT_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Anthropic (used when AGENT_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# Optional: only for an Anthropic-compatible endpoint (e.g. Azure AI Foundry).
ANTHROPIC_BASE_URL=

# Gemini (used when AGENT_PROVIDER=gemini)
GEMINI_API_KEY=

# Browser channel: chrome | msedge | chromium
BROWSER_CHANNEL=chrome

# Which monitor MSS captures for screenshots: 1 = primary, 2 = external.
SCREENSHOT_MONITOR=1

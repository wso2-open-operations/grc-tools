# Backend environment variables
# Copy this file to .env and fill in your values.

# PostgreSQL connection string. Any Postgres works — Neon, Azure Database for
# PostgreSQL, or a local instance — just swap this URL; no code changes needed.
DATABASE_URL=postgresql://user:password@host:5432/compliance_db

# Asgardeo organization (tenant) name — used to build the UserInfo endpoint
# that validates every request's Bearer token.
ASGARDEO_ORG=your-asgardeo-org

# Comma-separated allow-list of emails granted the "admin" role.
# Everyone else who authenticates gets "engineer".
ADMIN_EMAILS=

# Azure Blob Storage for evidence files (required — there is no local fallback).
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=uploads

# Comma-separated CORS allow-list for the web frontend.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
